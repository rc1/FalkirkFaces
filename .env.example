# Gemini API key — required for embedding face crops and text queries.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# --- Optional overrides (sensible defaults live in lib/paths.ts & lib/config.ts) ---

# Multimodal embedding model + vector size.
# EMBED_MODEL=gemini-embedding-2
# EMBED_DIM=768

# Where the source images live (folder is scanned for faces).
# SOURCE_DIR=./photos

# Where all generated data goes (crops, thumbs, lancedb, manifest).
# DATA_DIR=./volumes

# Detection thresholds.
# MIN_FACE_WIDTH=96
# MIN_FACE_HEIGHT=96
# MIN_DETECTOR_CONFIDENCE=0.6
